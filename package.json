{
  "name": "minitools",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "postinstall": "patch-package",
    "start": "expo start --localhost",
    "start:clear": "expo start --localhost --clear",
    "start:tunnel": "expo start --tunnel",
    "start:wifi": "sh -c 'for IFACE in en0 en1; do IP=$(ipconfig getifaddr \"$IFACE\" 2>/dev/null); [ -n \"$IP\" ] && break; done; if [ -z \"$IP\" ]; then echo \"No IP on en0/en1 — connect Wi‑Fi or Ethernet\"; exit 1; fi; echo \"Packager host: $IP\"; export REACT_NATIVE_PACKAGER_HOSTNAME=\"$IP\"; exec expo start'",
    "start:lan": "expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "gen:interview-json": "node scripts/gen-interview-json.cjs"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "^7.15.5",
    "@react-navigation/elements": "^2.9.12",
    "@react-navigation/native": "~7.2.0",
    "expo": "~55.0.0",
    "expo-asset": "~55.0.10",
    "expo-clipboard": "~55.0.9",
    "expo-constants": "~55.0.9",
    "expo-device": "~55.0.10",
    "expo-document-picker": "~55.0.9",
    "expo-file-system": "~55.0.11",
    "expo-font": "~55.0.4",
    "expo-haptics": "~55.0.9",
    "expo-image": "~55.0.6",
    "expo-linear-gradient": "~55.0.9",
    "expo-linking": "~55.0.8",
    "expo-router": "~55.0.7",
    "expo-splash-screen": "~55.0.12",
    "expo-status-bar": "~55.0.4",
    "expo-symbols": "~55.0.5",
    "expo-system-ui": "~55.0.10",
    "expo-web-browser": "~55.0.10",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.2",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.7.2"
  },
  "devDependencies": {
    "@react-native-community/cli": "latest",
    "@types/react": "~19.2.10",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~55.0.0",
    "patch-package": "^8.0.1",
    "typescript": "~5.9.2"
  },
  "private": true,
  "engines": {
    "node": ">=20.19.4"
  }
}
