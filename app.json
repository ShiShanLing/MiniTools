{
  "expo": {
    "name": "MiniTools",
    "slug": "MiniTools",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icons/ios/AppIcon.appiconset/icon-1024.png",
    "scheme": "minitools",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.MiniTools"
    },
    "android": {
      "versionCode": 1,
      "permissions": [
        "android.permission.SCHEDULE_EXACT_ALARM"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/icons/ios/AppIcon.appiconset/icon-1024.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.MiniTools"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/icons/ios/AppIcon.appiconset/icon-1024.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/icons/ios/AppIcon.appiconset/icon-1024.png",
          "color": "#E6F4FE",
          "sounds": [],
          "mode": "production"
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#ffffff",
          "resizeMode": "cover",
          "enableFullScreenImage_legacy": true,
          "dark": {
            "backgroundColor": "#000000"
          },
          "ios": {
            "image": "./assets/splash/splash-9x16.png",
            "tabletImage": "./assets/splash/splash-3x2.png",
            "resizeMode": "cover",
            "enableFullScreenImage_legacy": true
          },
          "android": {
            "image": "./assets/splash/splash-9x16.png",
            "resizeMode": "cover"
          }
        }
      ],
      "expo-font",
      "expo-image",
      "expo-web-browser",
      "expo-asset",
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": false
    }
  }
}
