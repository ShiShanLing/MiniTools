{
  "expo": {
    "name": "MiniTools",
    "slug": "MiniTools",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icons/ios/AppIcon.appiconset/icon-1024.png",
    "scheme": "minitools",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.MiniTools"
    },
    "android": {
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/icons/ios/AppIcon.appiconset/icon-1024.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.MiniTools"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/icons/ios/AppIcon.appiconset/icon-1024.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/icons/ios/AppIcon.appiconset/icon-1024.png",
          "color": "#E6F4FE",
          "sounds": [],
          "mode": "production"
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/icons/ios/AppIcon.appiconset/icon-1024.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-font",
      "expo-image",
      "expo-web-browser",
      "expo-asset"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": false
    }
  }
}
